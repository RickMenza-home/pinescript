//@version=6
indicator("EPS and P/E history", overlay=true)

MAX_NUMBER_OF_HISTORICAL_REPORTS = 10
NOT_AVAILABLE_STRING = "N/A"
MIN_NUMBER_OF_HISTORICAL_REPORTS_FOR_AVERAGING = 5

// Function that around to 2 decimals
truncate(num) =>
    factor = math.pow(10, 2)
    int(num * factor) / factor

// --- pull EPS
eps_current = request.financial(syminfo.tickerid, "EARNINGS_PER_SHARE_DILUTED", "TTM")
eps_historic = request.financial(syminfo.tickerid, "EARNINGS_PER_SHARE_DILUTED", "FY")

// --- detect new annual report
new_report = not na(eps_historic) and eps_historic != eps_historic[1]

getEpsHistoric(occurence) =>
    ta.valuewhen(new_report, eps_historic, occurence)

getEpsHistoricString(occurence) =>
    eps_ = getEpsHistoric(occurence)
    if not na(eps_) and eps_ != 0
        str.tostring(truncate(eps_))
    else
        NOT_AVAILABLE_STRING

getPeHistoric(occurence) =>
    eps_ = getEpsHistoric(occurence)
    if not na(eps_) and eps_ != 0
        ta.valuewhen(new_report, close, occurence) / eps_
    else
        na

getPeHistoricString(occurence) =>
    pe_ = getPeHistoric(occurence)
    if not na(pe_)
        str.tostring(truncate(pe_))
    else
        NOT_AVAILABLE_STRING

getYearHistoricString(occurence) =>
    year_ = ta.valuewhen(new_report, year, occurence)
    if not na(year_)
        str.tostring(year_)
    else
        NOT_AVAILABLE_STRING

// precompute year/EPS strings once per calc for consistent rendering.
max_years = 0
year_strings = array.new_string()
eps_strings = array.new_string()
pe_strings = array.new_string()
eps_values = array.new_float()
pe_values = array.new_float()

f_get(occurence) =>
    [getYearHistoricString(occurence), getEpsHistoric(occurence), getEpsHistoricString(occurence), getPeHistoric(occurence), getPeHistoricString(occurence)]

f_getHistoricRow(occurrence) =>
    [yr_string, eps_value, eps_string, pe_value, pe_string] = f_get(occurrence)
    valid = not na(eps_value) and eps_value != 0
    [valid, yr_string, eps_value, eps_string, pe_value, pe_string]

addHistoricRow(occurrence) =>
    [valid, yr_string, eps_value, eps_string, pe_value, pe_string] = f_getHistoricRow(occurrence)
    if valid
        array.push(year_strings, yr_string)
        array.push(eps_strings, eps_string)
        array.push(pe_strings, pe_string)
        array.push(eps_values, eps_value)
        array.push(pe_values, pe_value)
    valid

if MAX_NUMBER_OF_HISTORICAL_REPORTS > 0
    if addHistoricRow(0)
        max_years := max_years + 1
if MAX_NUMBER_OF_HISTORICAL_REPORTS > 1
    if addHistoricRow(1)
        max_years := max_years + 1
if MAX_NUMBER_OF_HISTORICAL_REPORTS > 2
    if addHistoricRow(2)
        max_years := max_years + 1
if MAX_NUMBER_OF_HISTORICAL_REPORTS > 3
    if addHistoricRow(3)
        max_years := max_years + 1
if MAX_NUMBER_OF_HISTORICAL_REPORTS > 4
    if addHistoricRow(4)
        max_years := max_years + 1
if MAX_NUMBER_OF_HISTORICAL_REPORTS > 5
    if addHistoricRow(5)
        max_years := max_years + 1
if MAX_NUMBER_OF_HISTORICAL_REPORTS > 6
    if addHistoricRow(6)
        max_years := max_years + 1
if MAX_NUMBER_OF_HISTORICAL_REPORTS > 7
    if addHistoricRow(7)
        max_years := max_years + 1
if MAX_NUMBER_OF_HISTORICAL_REPORTS > 8
    if addHistoricRow(8)
        max_years := max_years + 1
if MAX_NUMBER_OF_HISTORICAL_REPORTS > 9
    if addHistoricRow(9)
        max_years := max_years + 1
if MAX_NUMBER_OF_HISTORICAL_REPORTS > 10
    if addHistoricRow(10)
        max_years := max_years + 1

getPeAverage() =>
    size = array.size(pe_values)
    sum = 0.0
    count = 0
    min_val = 1e20
    max_val = -1e20
    for i = 0 to size - 1
        pe_ = array.get(pe_values, i)
        if not na(pe_)
            sum += pe_
            count += 1
            min_val := math.min(min_val, pe_)
            max_val := math.max(max_val, pe_)
    if count == 0
        na
    else if count >= MIN_NUMBER_OF_HISTORICAL_REPORTS_FOR_AVERAGING
        filtered_sum = sum - min_val - max_val
        filtered_count = count - 2
        filtered_sum / filtered_count
    else
        sum / count

// ---- table
COLOR_BACKGROUND = color.black
COLOR_FRAME = COLOR_BACKGROUND
COLOR_BORDER = COLOR_BACKGROUND
COLOR_TEXT = color.white

TOTAL_NUMBER_OF_COLUMNS = 3
TOTAL_NUMBER_OF_ROWS = MAX_NUMBER_OF_HISTORICAL_REPORTS + 3 // title + historical rows + TTM + average
TABLE_BORDER_WIDTH = 1
TABLE_FRAME_WIDTH = 1
TABLE_TITLE_TEXT_ALIGN = text.align_center
TABLE_TEXT_SIZE = size.normal
TABLE_KEY_TEXT_ALIGN = text.align_right
TABLE_VALUE_TEXT_ALIGN = text.align_center

var myTable = table.new(position = position.top_right, columns = TOTAL_NUMBER_OF_COLUMNS, rows = TOTAL_NUMBER_OF_ROWS, bgcolor = COLOR_BACKGROUND, border_width = TABLE_BORDER_WIDTH, frame_color = COLOR_FRAME, frame_width = TABLE_FRAME_WIDTH, border_color = COLOR_BORDER)
if barstate.islast
    table.set_bgcolor(myTable, COLOR_BACKGROUND)
    table.set_frame_color(myTable, COLOR_FRAME)
    table.set_border_color(myTable, COLOR_BORDER)

    rowIndex = 0

    // Header labels
    table.cell(table_id = myTable, column = 1, row = rowIndex, text = "EPS", text_color = COLOR_TEXT, bgcolor = COLOR_BACKGROUND, text_halign = TABLE_TITLE_TEXT_ALIGN, text_size = TABLE_TEXT_SIZE)
    table.cell(table_id = myTable, column = 2, row = rowIndex, text = "P/E", text_color = COLOR_TEXT, bgcolor = COLOR_BACKGROUND, text_halign = TABLE_TITLE_TEXT_ALIGN, text_size = TABLE_TEXT_SIZE)

    rowIndex += 1
    occurrence = 0
    if max_years == 0
        table.cell(table_id = myTable, column = 0, row = rowIndex, text = "No historical EPS", text_color = COLOR_TEXT, bgcolor = COLOR_BACKGROUND, text_halign = text.align_center, text_size = TABLE_TEXT_SIZE)
        table.merge_cells(table_id = myTable, start_column = 0, start_row = rowIndex, end_column = 2, end_row = rowIndex)
        occurrence += 1
    else
        for i = rowIndex to max_years + rowIndex - 1
            year_string = array.get(year_strings, occurrence)
            eps_string = array.get(eps_strings, occurrence)
            pe_string = array.get(pe_strings, occurrence)
            table.cell(table_id = myTable, column = 0, row = i, text = year_string, text_color = COLOR_TEXT, bgcolor = COLOR_BACKGROUND, text_halign = TABLE_KEY_TEXT_ALIGN, text_size = TABLE_TEXT_SIZE)
            table.cell(table_id = myTable, column = 1, row = i, text = eps_string, text_color = COLOR_TEXT, bgcolor = COLOR_BACKGROUND, text_halign = TABLE_VALUE_TEXT_ALIGN, text_size = TABLE_TEXT_SIZE)
            table.cell(table_id = myTable, column = 2, row = i, text = pe_string, text_color = COLOR_TEXT, bgcolor = COLOR_BACKGROUND, text_halign = TABLE_VALUE_TEXT_ALIGN, text_size = TABLE_TEXT_SIZE)
            occurrence += 1

    rowIndex += occurrence
    table.cell(table_id = myTable, column = 0, row = rowIndex, text = "TTM", text_color = COLOR_TEXT, bgcolor = COLOR_BACKGROUND, text_halign = TABLE_KEY_TEXT_ALIGN, text_size = TABLE_TEXT_SIZE)
    eps_text = not na(eps_current) ? str.tostring(truncate(eps_current)) : "N/A"
    table.cell(table_id = myTable, column = 1, row = rowIndex, text = eps_text, text_color = COLOR_TEXT, bgcolor = COLOR_BACKGROUND, text_halign = TABLE_VALUE_TEXT_ALIGN, text_size = TABLE_TEXT_SIZE)
    pe_current = not na(eps_current) and eps_current != 0 ? close / eps_current : na
    table.cell(table_id = myTable, column = 2, row = rowIndex, text = not na(pe_current) ? str.tostring(truncate(pe_current)) : "N/A", text_color = COLOR_TEXT, bgcolor = COLOR_BACKGROUND, text_halign = TABLE_VALUE_TEXT_ALIGN, text_size = TABLE_TEXT_SIZE)

    rowIndex += 1
    if max_years != 0
        table.cell(table_id = myTable, column = 0, row = rowIndex, text = "Average", text_color = COLOR_TEXT, bgcolor = COLOR_BACKGROUND, text_halign = TABLE_KEY_TEXT_ALIGN, text_size = TABLE_TEXT_SIZE)
        pe_average = getPeAverage()
        table.cell(table_id = myTable, column = 2, row = rowIndex, text = not na(pe_average) ? str.tostring(truncate(pe_average)) : "N/A", text_color = COLOR_TEXT, bgcolor = COLOR_BACKGROUND, text_halign = TABLE_VALUE_TEXT_ALIGN, text_size = TABLE_TEXT_SIZE)