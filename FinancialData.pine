//@version=6
indicator("Financial Data", overlay = true, format = format.volume, precision = 2)

// Constants
COLOR_BACKGROUND = color.black
COLOR_FRAME = COLOR_BACKGROUND
COLOR_BORDER = COLOR_BACKGROUND
COLOR_TEXT = color.white
TABLE_BORDER_WIDTH = 1
TABLE_FRAME_WIDTH = 1
TABLE_KEY_TEXT_ALIGN = text.align_right
TABLE_VALUE_TEXT_ALIGN = text.align_center
TABLE_TITLE_TEXT_ALIGN = text.align_center
TABLE_TEXT_SIZE = size.normal

COLOR_ALERT = color.red
COLOR_WARNING = color.orange
COLOR_GOOD = color.green
COLOR_NEUTRAL = COLOR_BACKGROUND

FLOAT_ALERT = 50
FLOAT_GOOD = 100

PE_ALERT = 25
PE_GOOD = 15
PE_ALERT_LEVEL2 = 0

EPS_ALERT = 0

PB_ALERT = 3.5
PB_GOOD = 1.5

DE_GOOD = 1

DIVIDEND_GOOD = 0

GROSS_MARGIN_ALERT = 0
GROSS_MARGIN_GOOD = 30

NET_MARGIN_ALERT = 0
NET_MARGIN_GOOD = 5

// Function that around to 2 decimals
truncate(num) =>
    factor = math.pow(10, 2)
    int(num * factor) / factor

// SECTOR
string sector = syminfo.sector
string subSector = syminfo.industry

// FLOAT
floatShares = request.financial(syminfo.tickerid, "FLOAT_SHARES_OUTSTANDING", "FY") / 1000000
getFloatColor() =>
    color color = na
    if(floatShares < FLOAT_ALERT)
        color := COLOR_ALERT
    else if(floatShares >= FLOAT_GOOD)
        color := COLOR_GOOD
    else
        color := COLOR_WARNING
    color

// EARNING PER SHARE
// Earnings per share (EPS) is a company's net profit divided by the number of common shares it has outstanding.
EPS = request.financial(syminfo.tickerid, "EARNINGS_PER_SHARE_DILUTED", "TTM")
getEpsColor() =>
    color color = na
    if(EPS <= EPS_ALERT)
        color := COLOR_ALERT
    else
        color := COLOR_GOOD
    color

// PRICE EARNING RATIO
// Price Earnings Ratio is calculated by dividing the current market price per share by the earnings per share for the last 12-month period.
PriceEarningsRatio = close / EPS
peTextColor = PriceEarningsRatio < 0 ? COLOR_ALERT : COLOR_TEXT
getPeColor() =>
    color color = na
    if(PriceEarningsRatio > PE_ALERT)
        color := COLOR_ALERT
    else if(PriceEarningsRatio < PE_ALERT_LEVEL2)
        color := COLOR_BACKGROUND
    else if(PriceEarningsRatio <= PE_GOOD)
        color := COLOR_GOOD
    else
        color := COLOR_WARNING
    color

// BOOK VALUE PER SHARE
// Book value per share (BVPS) is the ratio of equity available to common shareholders divided by the number of outstanding shares. 
BVPS  = request.financial(syminfo.tickerid, "BOOK_VALUE_PER_SHARE", "FQ")
// PRICE BOOK RATIO
// Price Book Ratio is calculated by dividing the price per share by the book value per share.
PriceBookRatio = close / BVPS
getPriceBookRatioColor() =>
    color color = na
    if(PriceBookRatio > PB_ALERT)
        color := COLOR_ALERT
    else if(PriceBookRatio < PB_GOOD)
        color := COLOR_GOOD
    else
        color := COLOR_WARNING
    color

// DEBT TO EQUITY RATIO
// Debt to equity ratio is the ratio of Total debt to Total equity
DE = request.financial(syminfo.tickerid, "DEBT_TO_EQUITY", "FQ")
getDeRatioColor() =>
    color color = COLOR_NEUTRAL
    if(DE < DE_GOOD)
        color := COLOR_GOOD
    color

// EPS diluted one year growth
EPS_diluted_one_year_growth = request.financial(syminfo.tickerid, "EARNINGS_PER_SHARE_BASIC_ONE_YEAR_GROWTH", "FQ")

// PRICE EARNING TO GROWTH RATIO
// It is the P/E ratio (price-to-earnings ratio) divided by the growth rate.
PEG = PriceEarningsRatio / EPS_diluted_one_year_growth
getPegRatioColor() =>
    COLOR_NEUTRAL

// DIVIDEND
dividend = request.financial(syminfo.tickerid, "DIVIDENDS_YIELD", "FQ")
getDividendColor() =>
    color color = na
    if(dividend <= DIVIDEND_GOOD)
        color := COLOR_NEUTRAL
    else
        color := COLOR_GOOD
    color

// GROSS MARGIN
grossMargin = request.financial(syminfo.tickerid, "GROSS_MARGIN", "FQ")
getGrossMarginColor() =>
    color color = na
    if(grossMargin < GROSS_MARGIN_ALERT)
        color := COLOR_ALERT
    else if(grossMargin >= GROSS_MARGIN_GOOD)
        color := COLOR_GOOD
    else
        color := COLOR_WARNING
    color

// NET MARGIN
netMargin = request.financial(syminfo.tickerid, "NET_MARGIN", "FQ")
getNetMarginColor() =>
    color color = na
    if(grossMargin < NET_MARGIN_ALERT)
        color := COLOR_ALERT
    else if(grossMargin >= NET_MARGIN_GOOD)
        color := COLOR_GOOD
    else
        color := COLOR_WARNING
    color

// CASH FROM OPERATING_ACTIVITIES
CFOA = request.financial(syminfo.tickerid, "CASH_F_OPERATING_ACTIVITIES", "TTM")
getCfoaColor() =>
    COLOR_NEUTRAL

// EBIT
EBIT = request.financial(syminfo.tickerid, "EBIT", "TTM")
getEbitColor() =>
    COLOR_NEUTRAL

// EBITDA
EBITDA = request.financial(syminfo.tickerid, "EBITDA", "TTM")
getEbitdaColor() =>
    COLOR_NEUTRAL

// RETURN ON ASSETS RATIO
ROA = request.financial(syminfo.tickerid, "RETURN_ON_ASSETS", "FQ")
getRoaColor() =>
    COLOR_NEUTRAL

// RETURN ON EQUITY RATIO
ROE = request.financial(syminfo.tickerid, "RETURN_ON_EQUITY", "FQ")
getRoeColor() =>
    COLOR_NEUTRAL

// RETURN ON INVESTED CAPITAL RATIO
ROIC = request.financial(syminfo.tickerid, "RETURN_ON_INVESTED_CAPITAL", "FQ")
getRoicColor() =>
    COLOR_NEUTRAL

// Display table
var myTable = table.new(position = position.bottom_right, columns = 2, rows = 17, bgcolor = COLOR_BACKGROUND, border_width = TABLE_BORDER_WIDTH, frame_color = COLOR_FRAME, frame_width = TABLE_FRAME_WIDTH, border_color = COLOR_BORDER)
if(barstate.islast)
    table.set_bgcolor(myTable, COLOR_BACKGROUND)
    table.set_frame_color(myTable, COLOR_FRAME)
    table.set_border_color(myTable, COLOR_BORDER)

    titleRowIndex = 0
    table.cell(table_id = myTable, column = 0, row = titleRowIndex, text = sector, text_color = COLOR_TEXT, bgcolor = COLOR_BACKGROUND, text_halign = TABLE_TITLE_TEXT_ALIGN, text_size = TABLE_TEXT_SIZE)
    table.merge_cells(table_id = myTable, start_column = 0, start_row = titleRowIndex, end_column = 1, end_row = titleRowIndex)
    titleRowIndex := titleRowIndex + 1
    table.cell(table_id = myTable, column = 0, row = titleRowIndex, text = subSector, text_color = COLOR_TEXT, bgcolor = COLOR_BACKGROUND, text_halign = TABLE_TITLE_TEXT_ALIGN, text_size = TABLE_TEXT_SIZE)
    table.merge_cells(table_id = myTable, start_column = 0, start_row = titleRowIndex, end_column = 1, end_row = titleRowIndex)

    rowIndex = titleRowIndex + 1
    table.cell(table_id = myTable, column = 0, row = rowIndex, text = "FLOAT", text_color = COLOR_TEXT, bgcolor = COLOR_BACKGROUND, text_halign = TABLE_KEY_TEXT_ALIGN, text_size = TABLE_TEXT_SIZE)
    rowIndex := rowIndex + 1
    table.cell(table_id = myTable, column = 0, row = rowIndex, text = "P/E", text_color = COLOR_TEXT, bgcolor = COLOR_BACKGROUND, text_halign = TABLE_KEY_TEXT_ALIGN, text_size = TABLE_TEXT_SIZE)
    rowIndex := rowIndex + 1
    table.cell(table_id = myTable, column = 0, row = rowIndex, text = "EPS", text_color = COLOR_TEXT, bgcolor = COLOR_BACKGROUND, text_halign = TABLE_KEY_TEXT_ALIGN, text_size = TABLE_TEXT_SIZE)
    rowIndex := rowIndex + 1
    table.cell(table_id = myTable, column = 0, row = rowIndex, text = "P/B", text_color = COLOR_TEXT, bgcolor = COLOR_BACKGROUND, text_halign = TABLE_KEY_TEXT_ALIGN, text_size = TABLE_TEXT_SIZE)
    rowIndex := rowIndex + 1
    table.cell(table_id = myTable, column = 0, row = rowIndex, text = "D/E", text_color = COLOR_TEXT, bgcolor = COLOR_BACKGROUND, text_halign = TABLE_KEY_TEXT_ALIGN, text_size = TABLE_TEXT_SIZE)
    rowIndex := rowIndex + 1
    table.cell(table_id = myTable, column = 0, row = rowIndex, text = "PEG", text_color = COLOR_TEXT, bgcolor = COLOR_BACKGROUND, text_halign = TABLE_KEY_TEXT_ALIGN, text_size = TABLE_TEXT_SIZE)
    rowIndex := rowIndex + 1
    table.cell(table_id = myTable, column = 0, row = rowIndex, text = "DIVIDEND", text_color = COLOR_TEXT, bgcolor = COLOR_BACKGROUND, text_halign = TABLE_KEY_TEXT_ALIGN, text_size = TABLE_TEXT_SIZE)
    rowIndex := rowIndex + 1
    table.cell(table_id = myTable, column = 0, row = rowIndex, text = "GR. MARGIN", text_color = COLOR_TEXT, bgcolor = COLOR_BACKGROUND, text_halign = TABLE_KEY_TEXT_ALIGN, text_size = TABLE_TEXT_SIZE)
    rowIndex := rowIndex + 1
    table.cell(table_id = myTable, column = 0, row = rowIndex, text = "NET MARGIN", text_color = COLOR_TEXT, bgcolor = COLOR_BACKGROUND, text_halign = TABLE_KEY_TEXT_ALIGN, text_size = TABLE_TEXT_SIZE)
    rowIndex := rowIndex + 1
    table.cell(table_id = myTable, column = 0, row = rowIndex, text = "CASH FLOW", text_color = COLOR_TEXT, bgcolor = COLOR_BACKGROUND, text_halign = TABLE_KEY_TEXT_ALIGN, text_size = TABLE_TEXT_SIZE)
    rowIndex := rowIndex + 1
    table.cell(table_id = myTable, column = 0, row = rowIndex, text = "EBIT", text_color = COLOR_TEXT, bgcolor = COLOR_BACKGROUND, text_halign = TABLE_KEY_TEXT_ALIGN, text_size = TABLE_TEXT_SIZE)
    rowIndex := rowIndex + 1
    table.cell(table_id = myTable, column = 0, row = rowIndex, text = "EBITDA", text_color = COLOR_TEXT, bgcolor = COLOR_BACKGROUND, text_halign = TABLE_KEY_TEXT_ALIGN, text_size = TABLE_TEXT_SIZE)
    rowIndex := rowIndex + 1
    table.cell(table_id = myTable, column = 0, row = rowIndex, text = "ROA", text_color = COLOR_TEXT, bgcolor = COLOR_BACKGROUND, text_halign = TABLE_KEY_TEXT_ALIGN, text_size = TABLE_TEXT_SIZE)
    rowIndex := rowIndex + 1
    table.cell(table_id = myTable, column = 0, row = rowIndex, text = "ROE", text_color = COLOR_TEXT, bgcolor = COLOR_BACKGROUND, text_halign = TABLE_KEY_TEXT_ALIGN, text_size = TABLE_TEXT_SIZE)
    rowIndex := rowIndex + 1
    table.cell(table_id = myTable, column = 0, row = rowIndex, text = "ROIC", text_color = COLOR_TEXT, bgcolor = COLOR_BACKGROUND, text_halign = TABLE_KEY_TEXT_ALIGN, text_size = TABLE_TEXT_SIZE)
    
    rowIndex := titleRowIndex + 1
    table.cell(table_id = myTable, column = 1, row = rowIndex, text = str.tostring(truncate(floatShares))+"M", text_color = COLOR_TEXT, bgcolor = getFloatColor(), text_halign = TABLE_VALUE_TEXT_ALIGN, text_size = TABLE_TEXT_SIZE)
    rowIndex := rowIndex + 1
    table.cell(table_id = myTable, column = 1, row = rowIndex, text = str.tostring(truncate(PriceEarningsRatio)), text_color = COLOR_TEXT, bgcolor = getPeColor(), text_halign = TABLE_VALUE_TEXT_ALIGN, text_size = TABLE_TEXT_SIZE)
    rowIndex := rowIndex + 1
    table.cell(table_id = myTable, column = 1, row = rowIndex, text = "$"+str.tostring(truncate(EPS)), text_color = peTextColor, bgcolor = getEpsColor(), text_halign = TABLE_VALUE_TEXT_ALIGN, text_size = TABLE_TEXT_SIZE)
    rowIndex := rowIndex + 1
    table.cell(table_id = myTable, column = 1, row = rowIndex, text = str.tostring(truncate(PriceBookRatio)), text_color = COLOR_TEXT, bgcolor = getPriceBookRatioColor(), text_halign = TABLE_VALUE_TEXT_ALIGN, text_size = TABLE_TEXT_SIZE)
    rowIndex := rowIndex + 1
    table.cell(table_id = myTable, column = 1, row = rowIndex, text = str.tostring(truncate(DE)), text_color = COLOR_TEXT, bgcolor = getDeRatioColor(), text_halign = TABLE_VALUE_TEXT_ALIGN, text_size = TABLE_TEXT_SIZE)
    rowIndex := rowIndex + 1
    table.cell(table_id = myTable, column = 1, row = rowIndex, text = str.tostring(truncate(PEG)), text_color = COLOR_TEXT, bgcolor = getPegRatioColor(), text_halign = TABLE_VALUE_TEXT_ALIGN, text_size = TABLE_TEXT_SIZE)
    rowIndex := rowIndex + 1
    table.cell(table_id = myTable, column = 1, row = rowIndex, text = str.tostring(truncate(dividend))+"%", text_color = COLOR_TEXT, bgcolor = getDividendColor(), text_halign = TABLE_VALUE_TEXT_ALIGN, text_size = TABLE_TEXT_SIZE)
    rowIndex := rowIndex + 1
    table.cell(table_id = myTable, column = 1, row = rowIndex, text = str.tostring(truncate(grossMargin))+"%", text_color = COLOR_TEXT, bgcolor = getGrossMarginColor(), text_halign = TABLE_VALUE_TEXT_ALIGN, text_size = TABLE_TEXT_SIZE)
    rowIndex := rowIndex + 1
    table.cell(table_id = myTable, column = 1, row = rowIndex, text = str.tostring(truncate(netMargin))+"%", text_color = COLOR_TEXT, bgcolor = getNetMarginColor(), text_halign = TABLE_VALUE_TEXT_ALIGN, text_size = TABLE_TEXT_SIZE)
    rowIndex := rowIndex + 1
    table.cell(table_id = myTable, column = 1, row = rowIndex, text = str.tostring(truncate(CFOA)), text_color = COLOR_TEXT, bgcolor = getCfoaColor(), text_halign = TABLE_VALUE_TEXT_ALIGN, text_size = TABLE_TEXT_SIZE)
    rowIndex := rowIndex + 1
    table.cell(table_id = myTable, column = 1, row = rowIndex, text = str.tostring(truncate(EBIT)), text_color = COLOR_TEXT, bgcolor = getEbitColor(), text_halign = TABLE_VALUE_TEXT_ALIGN, text_size = TABLE_TEXT_SIZE)
    rowIndex := rowIndex + 1
    table.cell(table_id = myTable, column = 1, row = rowIndex, text = str.tostring(truncate(EBITDA)), text_color = COLOR_TEXT, bgcolor = getEbitdaColor(), text_halign = TABLE_VALUE_TEXT_ALIGN, text_size = TABLE_TEXT_SIZE)
    rowIndex := rowIndex + 1
    table.cell(table_id = myTable, column = 1, row = rowIndex, text = str.tostring(truncate(ROA)), text_color = COLOR_TEXT, bgcolor = getRoaColor(), text_halign = TABLE_VALUE_TEXT_ALIGN, text_size = TABLE_TEXT_SIZE)
    rowIndex := rowIndex + 1
    table.cell(table_id = myTable, column = 1, row = rowIndex, text = str.tostring(truncate(ROE)), text_color = COLOR_TEXT, bgcolor = getRoeColor(), text_halign = TABLE_VALUE_TEXT_ALIGN, text_size = TABLE_TEXT_SIZE)
    rowIndex := rowIndex + 1
    table.cell(table_id = myTable, column = 1, row = rowIndex, text = str.tostring(truncate(ROIC)), text_color = COLOR_TEXT, bgcolor = getRoicColor(), text_halign = TABLE_VALUE_TEXT_ALIGN, text_size = TABLE_TEXT_SIZE)
